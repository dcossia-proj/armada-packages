# Pinned by digest, not the :44 tag, so the build toolchain can't drift.
BUILDER_IMAGE=registry.fedoraproject.org/fedora@sha256:0c6072366ebf8ea1c8c0f3a118aad3e9a9247d3065d499e54d62968f69351966

# Baseline CPU flags for packages that opt into Armada-specific tuning. Keep
# this to features shared by Armada's current Snapdragon targets: SM8550 lacks
# bf16, and SM8750/Oryon does not expose SVE.
ARMADA_MARCH="-march=armv8.2-a+fp16+dotprod+i8mm -mtune=cortex-a78"
